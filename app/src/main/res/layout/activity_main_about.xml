<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
                android:id="@+id/txtModuleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:id="@+id/txtConfigWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone"
                android:layout_marginBottom="24dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_section_features"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_hide_icons"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_hide_icons_desc"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_rotation"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_rotation_desc"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_miku"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_miku_desc"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="24dp"/>

        <!-- Landscape Background feature section -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_landscape_bg"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_feature_landscape_bg_desc"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="12dp"/>

    </LinearLayout>

</ScrollView>
